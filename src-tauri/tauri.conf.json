{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小简-MD2CV简历工作台",
  "version": "0.1.1",
  "identifier": "com.dmx.max-md2cv-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:18080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "小简-MD2CV简历工作台",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../src/assets/templates/*.css": "templates/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "template": "./templates/installer.nsi"
      }
    }
  }
}
