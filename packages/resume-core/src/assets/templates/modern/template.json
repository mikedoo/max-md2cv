{
  "id": "modern",
  "name": "现代简约",
  "version": "1.0.0",
  "entryCss": "style.css",
  "description": "适合通用求职场景的现代风格简历模板。",
  "schemaPreset": "standard",
  "defaults": {
    "themeColor": "#4c49cc",
    "fontFamily": "\"Microsoft YaHei\", \"PingFang SC\", sans-serif",
    "fontSize": 14,
    "paragraphSpacing": 8,
    "h2MarginTop": 24,
    "h2MarginBottom": 12,
    "h3MarginTop": 12,
    "h3MarginBottom": 4,
    "personalHeaderSpacing": 24,
    "h1Size": 32,
    "h2Size": 18,
    "h3Size": 16,
    "dateSize": 14,
    "dateWeight": "700",
    "lineHeight": 1.5,
    "marginV": 10,
    "marginH": 12,
    "personalInfoMode": "icon",
    "headerLayout": "stack",
    "photoPlacement": "top-right",
    "sectionTitlePreset": "accent-bar"
  },
  "features": {
    "photo": true,
    "pageFooter": true,
    "contactModes": ["text", "icon"]
  },
  "layout": {
    "headerLayout": "stack",
    "personalInfoMode": "icon",
    "photoPlacement": "top-right",
    "sectionTitlePreset": "accent-bar"
  }
}
