    "personalHeaderSpacing": 8,
    "h1Size": 32,
    "h2Size": 18,
    "h3Size": 16,
    "dateSize": 14,
    "dateWeight": "400",
    "lineHeight": 1.5,
    "marginV": 10,
    "marginH": 12,
    "personalInfoMode": "text",
    "headerLayout": "stack",
    "photoPlacement": "top-right",
    "sectionTitlePreset": "underline"
  },
  "features": {
    "photo": true,
    "pageFooter": true,
    "contactModes": ["text", "icon"]
  },
  "layout": {
    "headerLayout": "stack",
    "personalInfoMode": "text",
    "photoPlacement": "top-right",
    "sectionTitlePreset": "underline"
  }
